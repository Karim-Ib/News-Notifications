[database]
path = oil_sentinel.db

[gdelt]
poll_interval_minutes = 15
# GDELT 2.0 DOC API -- no key required
base_url = https://api.gdeltproject.org/api/v2/doc/doc
# Max articles per query response
max_records = 250

# --- Pre-filter settings ---
# Tone threshold for tier-1 sources (Reuters, Bloomberg, AP, etc.)
tone_threshold = 2.5
# Tone threshold for unknown/low-credibility sources (higher = stricter)
unknown_source_tone_threshold = 5.0
# Drop articles whose published/seendate is older than this (hours)
max_article_age_hours = 12
# Comma-separated tier-1 domains -- these pass at the lower tone_threshold
tier1_sources = reuters.com,bloomberg.com,apnews.com,ft.com,wsj.com,aljazeera.com,bbc.com,bbc.co.uk,theguardian.com,nytimes.com,washingtonpost.com,oilprice.com,rigzone.com,platts.com,argusmedia.com

[market]
poll_interval_minutes = 5
# yfinance tickers for WTI and Brent
wti_ticker = CL=F
brent_ticker = BZ=F
# Rolling window (number of 5-min samples) for z-score baseline
zscore_window = 288
# Z-score threshold for anomaly flag
zscore_threshold = 2.0

[gemini]
api_key = API KEY
model = gemini-2.5-flash-lite
# Max articles sent to Gemini per scoring cycle
batch_size = 5
# Minimum GDELT relevance score to forward to Gemini (0-100)
min_relevance = 60

[telegram]
bot_token = YOUR_TELEGRAM_BOT_TOKEN_HERE
chat_id = YOUR_CHAT_ID_HERE
# Cooldown in minutes before resending alert on same narrative thread
cooldown_minutes = 60
# Minimum magnitude (0-10) for an immediate alert; signals below this go into the digest
alert_threshold = 7
# UTC hours to send the twice-daily digest of sub-threshold signals
digest_hours = 12,20

[logging]
level = INFO
file = oil_sentinel.log
